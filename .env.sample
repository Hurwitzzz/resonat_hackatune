# Copy this file to `.env` and fill in your key. `.env` is git-ignored.
# Your Cyanite API key is handed out by the organizers at HACKATUNE 2026.

CYANITE_API_KEY=
CYANITE_ACCOUNT=

# Optional. When omitted, intent compilation uses a deterministic local fallback.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
